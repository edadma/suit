// suit engine — View/Node tree, layout, hit-test, dispatch, render.
// Lives in the same `module suit` as hooks.sysl so the engine can name
// the Fiber type without an import. The Component variant carries a
// `(Fiber) -> View` render function; mount/rerender drive that fiber.
//
// host_draw_text / host_fill_rect / host_draw_image are the OS-facing
// draw primitives; render() emits them. Demos register their own
// JVM/OS-side handlers.

module suit

extern host_draw_text(x: int, y: int, text: string, r: int, g: int, b: int, a: int) -> int
extern host_fill_rect(x: int, y: int, w: int, h: int, r: int, g: int, b: int, a: int) -> int
extern host_draw_image(x: int, y: int, w: int, h: int, source: string) -> int

// OS-facing event/render loop contract — implemented by the host (JVM
// dev shell, OS layer, or test stub). Tags are the int returned by
// host_poll_event; coords for the latest mouse event are read via
// host_event_x / host_event_y. host_now_ms is a monotonic ms clock
// for animations. host_present_frame flushes the draw buffer to the
// screen; host_sleep_until_next_frame paces to vsync.
extern host_poll_event() -> int
extern host_event_x() -> int
extern host_event_y() -> int
extern host_event_key() -> int
extern host_event_text() -> string
extern host_now_ms() -> int
extern host_present_frame() -> int
extern host_sleep_until_next_frame() -> int

const EVENT_NONE:        int = 0
const EVENT_QUIT:        int = 1
const EVENT_MOUSE_PRESS: int = 2
const EVENT_MOUSE_REL:   int = 3
const EVENT_MOUSE_MOVE:  int = 4
const EVENT_KEY_DOWN:    int = 5
const EVENT_KEY_UP:      int = 6
const EVENT_FRAME:       int = 7

// Dispatch phase — distinguishes a fresh PRESS from a DRAG (move while
// pressed) or REL (release). Existing widgets (Button/Checkbox/Radio)
// only act on PRESS; Slider uses DRAG to keep emitting values as the
// thumb is dragged and REL to clear its dragging latch.
//
// Module-level so InputState's struct shape stays backward-compatible —
// probes that only synthesize press events don't have to thread the
// phase through their dispatch calls. Defaults to PHASE_PRESS so a
// raw `dispatch(node, InputState(x, y, true))` call still triggers
// click-style widgets without any setup.
const PHASE_IDLE:  int = 0
const PHASE_PRESS: int = 1
const PHASE_DRAG:  int = 2
const PHASE_REL:   int = 3
const PHASE_KEY:   int = 4

// A few keycodes Input cares about. The host can pass anything; the
// Input arm only special-cases backspace and ignores any non-printable
// code that arrives without text. Printable input is delivered as a
// non-empty `current_text` and inserted verbatim — no per-key ASCII
// switch-case in sysl.
const KEY_BACKSPACE: int = 8
const KEY_ENTER:     int = 13

var current_phase: int = 1   // PHASE_PRESS
var current_key:   int = 0
var current_text: string = ""

set_phase(p: int) -> int
    current_phase = p
    0

set_key_event(k: int, t: string) -> int
    current_key  = k
    current_text = t
    0

struct Rect
    x: int
    y: int
    w: int
    h: int

struct Size
    w: int
    h: int

struct Color
    r: int
    g: int
    b: int
    a: int

struct Insets
    top: int
    right: int
    bottom: int
    left: int

struct InputState
    mouse_x: int
    mouse_y: int
    mouse_pressed: bool

// Theme constants — match engine-mini so widgets sized in either world
// agree on natural dimensions.
const FONT_W: int    = 8
const LINE_H: int    = 18
const BTN_PAD_X: int = 12
const BTN_PAD_Y: int = 6
const CHK_GAP: int   = 6
const RADIO_GAP:    int = 6
const SLIDER_H:     int = 18
const SLIDER_TRACK: int = 4
const SLIDER_THUMB: int = 8
const INPUT_PAD_X:  int = 6
const INPUT_PAD_Y:  int = 4

// Focus identity — every focusable Node mints a unique non-zero id at
// mount time. `focused_id == 0` means "nothing focused". This dodges
// the "is this the same Node?" question entirely: focus is just an
// id-equality check, no enum-equality dance and no tree walk to clear
// stale focused-bool flags.
var next_focus_id: int = 0
var focused_id:    int = 0

// Overlay machinery — Portals defer their child's render to a second
// pass that runs after the main tree. The queue is rebuilt every
// frame: render() pushes Portal children, render_overlays() drains
// it. Layout and dispatch still walk Portal children inline (so
// bounds + hit-tests work on the same frame as the click), only the
// draw command emission is deferred.
//
// `screen_frame` carries the run_loop's outer rect so Portals can
// lay out their children against the full screen even when the
// declaring Component sits in some narrow corner of the tree. Set
// by run_loop at the top of each frame; defaults to (0, 0, 0, 0)
// which makes Portal layout a no-op when the engine is driven
// outside run_loop (e.g. unit tests that just call mount + render).
const OVERLAY_CAPACITY: int = 16
var overlay_queue: []Node
var overlay_count: int = 0
var overlay_initialized: bool = false
var screen_frame: Rect

ensure_overlay_init() -> int
    if !overlay_initialized then
        overlay_queue = (new [OVERLAY_CAPACITY]Node)[:]
        screen_frame = Rect(0, 0, 0, 0)
        overlay_initialized = true
        0
    else 0

set_screen_frame(f: Rect) -> int
    ensure_overlay_init()
    screen_frame = f
    0

push_overlay(n: Node) -> int
    ensure_overlay_init()
    overlay_queue[overlay_count] = n
    overlay_count = overlay_count + 1
    0

new_focus_id() -> int
    next_focus_id = next_focus_id + 1
    next_focus_id

set_focus(id: int) -> int
    focused_id = id
    0

// drop_last(s) — chop the last byte off a string. Used by Input
// when the user presses BACKSPACE. Sysl strings are immutable, so
// we materialize a fresh []byte via the language's `s[i]` byte
// indexing and rebuild via `string(buf)`. No std.strings dependency.
drop_last(s: string) -> string
    val n = len(s)
    if n <= 1 then ""
    else
        val buf = (new [n - 1]byte)[:]
        var i = 0
        while i < n - 1 do
            buf[i] = s[i]
            i = i + 1
        string(buf)

enum View
    Text(content: string)
    Button(label: string, on_click: () -> int)
    Spacer(flex: int)
    Image(source: string, width: int, height: int)
    Checkbox(label: string, checked: bool, on_toggle: (bool) -> int)
    Radio(label: string, selected: bool, on_select: () -> int)
    Slider(value: int, vmin: int, vmax: int, on_change: (int) -> int, width: int)
    Input(value: string, placeholder: string, on_change: (string) -> int, width: int)
    Sized(child: View, width: int, height: int)
    Center(child: View)
    Box(child: View, color: Color, padding: Insets)
    Stack(gap: int, children: []View)
    HStack(gap: int, children: []View)
    Portal(child: View)
    AbsolutePosition(child: View, ax: int, ay: int, aw: int, ah: int)
    Backdrop(color: Color)
    Component(render: (Fiber) -> View)
    ContextProvider(key: int, value: HookValue, child: View)
    Keyed(key: int, child: View)

struct TextNodeState
    view: View
    bounds: Rect

struct ButtonNodeState
    view: View
    bounds: Rect

struct SpacerNodeState
    view: View
    bounds: Rect

struct ImageNodeState
    view: View
    bounds: Rect

struct CheckboxNodeState
    view: View
    bounds: Rect

struct RadioNodeState
    view: View
    bounds: Rect

struct SliderNodeState
    view: View
    bounds: Rect
    dragging: bool

struct InputNodeState
    view: View
    bounds: Rect
    focus_id: int

struct SizedNodeState
    view: View
    bounds: Rect
    child: Node

struct CenterNodeState
    view: View
    bounds: Rect
    child: Node

struct BoxNodeState
    view: View
    bounds: Rect
    child: Node

struct StackNodeState
    view: View
    bounds: Rect
    gap: int
    children: []Node

struct HStackNodeState
    view: View
    bounds: Rect
    gap: int
    children: []Node

struct PortalNodeState
    view: View
    bounds: Rect
    child: Node

struct AbsolutePositionState
    view: View
    bounds: Rect
    child: Node

struct BackdropNodeState
    view: View
    bounds: Rect

struct ComponentNodeState
    view: View
    bounds: Rect
    fiber: Fiber
    child: Node

struct ContextProviderState
    view: View
    bounds: Rect
    key: int
    value: HookValue
    child: Node

struct KeyedNodeState
    view: View
    bounds: Rect
    key: int
    child: Node

enum Node
    TextNode(s: TextNodeState)
    ButtonNode(s: ButtonNodeState)
    SpacerNode(s: SpacerNodeState)
    ImageNode(s: ImageNodeState)
    CheckboxNode(s: CheckboxNodeState)
    RadioNode(s: RadioNodeState)
    SliderNode(s: SliderNodeState)
    InputNode(s: InputNodeState)
    SizedNode(s: SizedNodeState)
    CenterNode(s: CenterNodeState)
    BoxNode(s: BoxNodeState)
    StackNode(s: StackNodeState)
    HStackNode(s: HStackNodeState)
    PortalNode(s: PortalNodeState)
    AbsolutePositionNode(s: AbsolutePositionState)
    BackdropNode(s: BackdropNodeState)
    ComponentNode(s: ComponentNodeState)
    ContextProviderNode(s: ContextProviderState)
    KeyedNode(s: KeyedNodeState)

// Module-level context stack — pushed when mount/rerender enters a
// ContextProvider's subtree, popped on the way back. use_context walks
// from top of stack down so nearest provider for a given key wins
// (matches React's nested-Provider shadowing).
const CONTEXT_STACK_CAPACITY: int = 32

struct ContextEntry
    key: int
    value: HookValue

var context_stack: []ContextEntry
var context_depth: int = 0
var context_initialized: bool = false

ensure_context_init() -> int
    if !context_initialized then
        context_stack = (new [CONTEXT_STACK_CAPACITY]ContextEntry)[:]
        context_initialized = true
        0
    else 0

push_context(key: int, value: HookValue) -> int
    ensure_context_init()
    context_stack[context_depth] = ContextEntry(key, value)
    context_depth = context_depth + 1
    0

pop_context() -> int
    context_depth = context_depth - 1
    0

read_context(key: int) -> HookValue
    var i = context_depth - 1
    while i >= 0 do
        if context_stack[i].key == key then
            return context_stack[i].value
        i = i - 1
    Empty

// use_context — looks up the nearest enclosing provider for `key`.
// Doesn't consume a hook cell index because it has no per-fiber state;
// safe to call zero or many times per render.
use_context(f: Fiber, key: int) -> HookValue
    read_context(key)

mount(v: View) -> Node
    v match
        Text(_)           -> TextNode(TextNodeState(v, Rect(0, 0, 0, 0)))
        Button(_, _)      -> ButtonNode(ButtonNodeState(v, Rect(0, 0, 0, 0)))
        Spacer(_)         -> SpacerNode(SpacerNodeState(v, Rect(0, 0, 0, 0)))
        Image(_, _, _)    -> ImageNode(ImageNodeState(v, Rect(0, 0, 0, 0)))
        Checkbox(_, _, _) -> CheckboxNode(CheckboxNodeState(v, Rect(0, 0, 0, 0)))
        Radio(_, _, _)        -> RadioNode(RadioNodeState(v, Rect(0, 0, 0, 0)))
        Slider(_, _, _, _, _) -> SliderNode(SliderNodeState(v, Rect(0, 0, 0, 0), false))
        Input(_, _, _, _)     -> InputNode(InputNodeState(v, Rect(0, 0, 0, 0), new_focus_id()))
        Sized(c, _, _)    -> SizedNode(SizedNodeState(v, Rect(0, 0, 0, 0), mount(c)))
        Center(c)         -> CenterNode(CenterNodeState(v, Rect(0, 0, 0, 0), mount(c)))
        Box(c, _, _)      -> BoxNode(BoxNodeState(v, Rect(0, 0, 0, 0), mount(c)))
        Stack(g, kids) ->
            val n = len(kids)
            val nodes = (new [n]Node)[:]
            var i = 0
            while i < n do
                nodes[i] = mount(kids[i])
                i = i + 1
            StackNode(StackNodeState(v, Rect(0, 0, 0, 0), g, nodes))
        HStack(g, kids) ->
            val n = len(kids)
            val nodes = (new [n]Node)[:]
            var i = 0
            while i < n do
                nodes[i] = mount(kids[i])
                i = i + 1
            HStackNode(HStackNodeState(v, Rect(0, 0, 0, 0), g, nodes))
        Portal(c)              -> PortalNode(PortalNodeState(v, Rect(0, 0, 0, 0), mount(c)))
        AbsolutePosition(c, _, _, _, _) -> AbsolutePositionNode(AbsolutePositionState(v, Rect(0, 0, 0, 0), mount(c)))
        Backdrop(_)            -> BackdropNode(BackdropNodeState(v, Rect(0, 0, 0, 0)))
        Component(render_fn) ->
            val f = new_fiber()
            f.hook_index = 0
            val root = render_fn(f)
            ComponentNode(ComponentNodeState(v, Rect(0, 0, 0, 0), f, mount(root)))
        ContextProvider(key, value, child) ->
            push_context(key, value)
            val mounted_child = mount(child)
            pop_context()
            ContextProviderNode(ContextProviderState(v, Rect(0, 0, 0, 0), key, value, mounted_child))
        Keyed(key, child) ->
            KeyedNode(KeyedNodeState(v, Rect(0, 0, 0, 0), key, mount(child)))

// Natural width in pixels for a string at the engine's monospace font.
text_w(s: string) -> int = len(s) * FONT_W

// Spacer flex weight, or 0 for any non-Spacer node. Used by Stack
// layout to split the unclaimed pool between flex children.
flex_of(n: Node) -> int
    n match
        SpacerNode(s) ->
            s.view match
                Spacer(f) -> f
                _         -> 0
        _ -> 0

// measure — natural size of a Node's subtree before layout assigns
// concrete bounds. Wrapper variants forward to their child; Stack
// returns max-of-widths × sum-of-heights+gaps.
measure(n: Node) -> Size
    n match
        TextNode(s) ->
            s.view match
                Text(c) -> Size(text_w(c), LINE_H)
                _       -> Size(0, 0)
        ButtonNode(s) ->
            s.view match
                Button(l, _) -> Size(text_w(l) + BTN_PAD_X * 2, LINE_H + BTN_PAD_Y * 2)
                _            -> Size(0, 0)
        SpacerNode(_) -> Size(0, 0)
        ImageNode(s) ->
            s.view match
                Image(_, w, h) -> Size(w, h)
                _              -> Size(0, 0)
        CheckboxNode(s) ->
            s.view match
                Checkbox(l, _, _) -> Size(LINE_H + CHK_GAP + text_w(l), LINE_H)
                _                 -> Size(0, 0)
        RadioNode(s) ->
            s.view match
                Radio(l, _, _) -> Size(LINE_H + RADIO_GAP + text_w(l), LINE_H)
                _              -> Size(0, 0)
        SliderNode(s) ->
            s.view match
                Slider(_, _, _, _, w) -> Size(w, SLIDER_H)
                _                     -> Size(0, 0)
        InputNode(s) ->
            s.view match
                Input(_, _, _, w) -> Size(w, LINE_H + INPUT_PAD_Y * 2)
                _                 -> Size(0, 0)
        SizedNode(s) ->
            val cs = measure(s.child)
            s.view match
                Sized(_, w, h) ->
                    val sw = if w >= 0 then w else cs.w
                    val sh = if h >= 0 then h else cs.h
                    Size(sw, sh)
                _ -> cs
        CenterNode(s) -> measure(s.child)
        BoxNode(s) ->
            val cs = measure(s.child)
            s.view match
                Box(_, _, p) -> Size(cs.w + p.left + p.right, cs.h + p.top + p.bottom)
                _            -> cs
        StackNode(s) ->
            var w = 0
            var h = 0
            var i = 0
            while i < len(s.children) do
                val cs = measure(s.children[i])
                if cs.w > w then w = cs.w
                h = h + cs.h
                if i > 0 then h = h + s.gap
                i = i + 1
            Size(w, h)
        HStackNode(s) ->
            var w = 0
            var h = 0
            var i = 0
            while i < len(s.children) do
                val cs = measure(s.children[i])
                w = w + cs.w
                if cs.h > h then h = cs.h
                if i > 0 then w = w + s.gap
                i = i + 1
            Size(w, h)
        // Portal/Absolute/Backdrop are out-of-flow — they don't take
        // up space in their parent's Stack-flex calculations. Always
        // measure as zero so non-flex Stack children's natural-height
        // sums skip them entirely.
        PortalNode(_)           -> Size(0, 0)
        AbsolutePositionNode(_) -> Size(0, 0)
        BackdropNode(_)         -> Size(0, 0)
        ComponentNode(s)        -> measure(s.child)
        ContextProviderNode(s)  -> measure(s.child)
        KeyedNode(s)            -> measure(s.child)

set_rect(b: Rect, frame: Rect) -> int
    b.x = frame.x
    b.y = frame.y
    b.w = frame.w
    b.h = frame.h
    0

// layout — assign concrete bounds. Stack distributes leftover space to
// Spacer children proportional to their flex weight; non-flex children
// get their measured natural height. Single-child wrappers either
// pass the frame straight down (Sized), shrink to centered intrinsic
// size (Center), or pad before recursing (Box).
layout(n: Node, frame: Rect) -> int
    n match
        TextNode(s)     -> set_rect(s.bounds, frame)
        ButtonNode(s)   -> set_rect(s.bounds, frame)
        SpacerNode(s)   -> set_rect(s.bounds, frame)
        ImageNode(s)    -> set_rect(s.bounds, frame)
        CheckboxNode(s) -> set_rect(s.bounds, frame)
        RadioNode(s)    -> set_rect(s.bounds, frame)
        SliderNode(s)   -> set_rect(s.bounds, frame)
        InputNode(s)    -> set_rect(s.bounds, frame)
        SizedNode(s) ->
            set_rect(s.bounds, frame)
            layout(s.child, frame)
        CenterNode(s) ->
            val cs    = measure(s.child)
            val cx    = frame.x + (frame.w - cs.w) / 2
            val cy    = frame.y + (frame.h - cs.h) / 2
            val inner = Rect(cx, cy, cs.w, cs.h)
            // Own bounds = the centered child rect so hit-testing sees
            // the rendered area, not the surrounding parent frame.
            set_rect(s.bounds, inner)
            layout(s.child, inner)
        BoxNode(s) ->
            set_rect(s.bounds, frame)
            s.view match
                Box(_, _, p) ->
                    val inner = Rect(frame.x + p.left,
                                     frame.y + p.top,
                                     frame.w - p.left - p.right,
                                     frame.h - p.top - p.bottom)
                    layout(s.child, inner)
                _ -> 0
        StackNode(s) ->
            set_rect(s.bounds, frame)
            var fixed_total = 0
            var flex_total  = 0
            var i = 0
            while i < len(s.children) do
                val f = flex_of(s.children[i])
                if f > 0 then
                    flex_total = flex_total + f
                else
                    val sz = measure(s.children[i])
                    fixed_total = fixed_total + sz.h
                i = i + 1
            val n_kids = len(s.children)
            val gaps   = if n_kids > 1 then (n_kids - 1) * s.gap else 0
            val avail0 = frame.h - fixed_total - gaps
            val flex_pool = if avail0 > 0 then avail0 else 0
            var pos = frame.y
            i = 0
            while i < len(s.children) do
                val child = s.children[i]
                val f     = flex_of(child)
                val ch    = if f > 0 && flex_total > 0 then flex_pool * f / flex_total else measure(child).h
                layout(child, Rect(frame.x, pos, frame.w, ch))
                pos = pos + ch
                if i < n_kids - 1 then pos = pos + s.gap
                i = i + 1
            0
        HStackNode(s) ->
            // Same flex algorithm as StackNode, mirrored to x. Each
            // child gets the full frame height; widths are split
            // between fixed-natural and flex-pool the same way Stack
            // splits heights. flex_of() reuses the Spacer flex weight
            // — Spacer is axis-agnostic and stretches in whichever
            // direction its parent measures along.
            set_rect(s.bounds, frame)
            var fixed_total = 0
            var flex_total  = 0
            var i = 0
            while i < len(s.children) do
                val f = flex_of(s.children[i])
                if f > 0 then
                    flex_total = flex_total + f
                else
                    val sz = measure(s.children[i])
                    fixed_total = fixed_total + sz.w
                i = i + 1
            val n_kids = len(s.children)
            val gaps   = if n_kids > 1 then (n_kids - 1) * s.gap else 0
            val avail0 = frame.w - fixed_total - gaps
            val flex_pool = if avail0 > 0 then avail0 else 0
            var pos = frame.x
            i = 0
            while i < len(s.children) do
                val child = s.children[i]
                val f     = flex_of(child)
                val cw    = if f > 0 && flex_total > 0 then flex_pool * f / flex_total else measure(child).w
                layout(child, Rect(pos, frame.y, cw, frame.h))
                pos = pos + cw
                if i < n_kids - 1 then pos = pos + s.gap
                i = i + 1
            0
        PortalNode(s) ->
            // Lays the child out against the screen frame, ignoring
            // the caller's parent frame. This is the whole point of a
            // Portal — render in the foreground regardless of where in
            // the tree it was declared. Bounds for hit-testing follow
            // the child so a click on the portaled content reaches it
            // through the normal dispatch walk.
            ensure_overlay_init()
            layout(s.child, screen_frame)
            set_rect(s.bounds, screen_frame)
        AbsolutePositionNode(s) ->
            s.view match
                AbsolutePosition(_, ax, ay, aw, ah) ->
                    val r = Rect(ax, ay, aw, ah)
                    set_rect(s.bounds, r)
                    layout(s.child, r)
                _ -> 0
        BackdropNode(s) ->
            ensure_overlay_init()
            set_rect(s.bounds, screen_frame)
        ComponentNode(s) ->
            set_rect(s.bounds, frame)
            layout(s.child, frame)
        ContextProviderNode(s) ->
            set_rect(s.bounds, frame)
            layout(s.child, frame)
        KeyedNode(s) ->
            set_rect(s.bounds, frame)
            layout(s.child, frame)

contains(b: Rect, x: int, y: int) -> bool
    x >= b.x && x < b.x + b.w && y >= b.y && y < b.y + b.h

dispatch(n: Node, input: InputState) -> int
    n match
        ButtonNode(s) ->
            if current_phase == PHASE_PRESS && input.mouse_pressed && contains(s.bounds, input.mouse_x, input.mouse_y) then
                s.view match
                    Button(_, on_click) ->
                        on_click()
                        0
                    _ -> 0
            else 0
        CheckboxNode(s) ->
            if current_phase == PHASE_PRESS && input.mouse_pressed && contains(s.bounds, input.mouse_x, input.mouse_y) then
                s.view match
                    Checkbox(_, checked, on_toggle) ->
                        on_toggle(!checked)
                        0
                    _ -> 0
            else 0
        RadioNode(s) ->
            // Radios only fire when the press is over them AND they're
            // not already selected — matches the Scala suit behavior so
            // a click on the active option is a no-op rather than
            // re-firing on_select. Group exclusivity is the parent's job:
            // the controller flips one Radio's `selected` to true and
            // others to false on each emission.
            if current_phase == PHASE_PRESS && input.mouse_pressed && contains(s.bounds, input.mouse_x, input.mouse_y) then
                s.view match
                    Radio(_, selected, on_select) ->
                        if !selected then on_select() else 0
                        0
                    _ -> 0
            else 0
        InputNode(s) ->
            // Two responsibilities, both gated by phase. On PRESS we
            // own the focus model: a press anywhere on the tree visits
            // every Input, so each Input either claims focus (press
            // landed inside its bounds) or releases it (we hold focus
            // and the press landed elsewhere). On PHASE_KEY we apply
            // the edit if we're the focused Input — append the
            // printable text payload, drop the last byte on
            // BACKSPACE — and emit the new value via on_change.
            if current_phase == PHASE_PRESS then
                if contains(s.bounds, input.mouse_x, input.mouse_y) then
                    set_focus(s.focus_id)
                    0
                else if focused_id == s.focus_id then
                    set_focus(0)
                    0
                else 0
            else if current_phase == PHASE_KEY && focused_id == s.focus_id then
                s.view match
                    Input(value, _, on_change, _) ->
                        if current_key == KEY_BACKSPACE then
                            on_change(drop_last(value))
                            0
                        else if len(current_text) > 0 then
                            on_change(value + current_text)
                            0
                        else 0
                    _ -> 0
            else 0
        SliderNode(s) ->
            // Three-phase handling. PRESS arms the dragging latch and
            // emits the projected value at the click point. DRAG (a
            // MOUSE_MOVE while still pressed) keeps emitting whenever
            // the cursor moves — without a contains() check, since the
            // user may drag past the bounds and we still track. REL
            // clears the latch.
            //
            // The projection math (track_width = bounds.w - SLIDER_THUMB;
            // origin = bounds.x + SLIDER_THUMB/2) matches render's thumb
            // placement so the click point lines up with the rendered
            // thumb position.
            s.view match
                Slider(value, vmin, vmax, on_change, _) ->
                    val range = vmax - vmin
                    val tw    = s.bounds.w - SLIDER_THUMB
                    if current_phase == PHASE_PRESS && contains(s.bounds, input.mouse_x, input.mouse_y) then
                        s.dragging = true
                        if range > 0 && tw > 0 then
                            val tx0  = s.bounds.x + SLIDER_THUMB / 2
                            val rel0 = (input.mouse_x - tx0) * range / tw
                            val rel  = if rel0 < 0 then 0 else if rel0 > range then range else rel0
                            val v    = vmin + rel
                            if v != value then on_change(v) else 0
                            0
                        else 0
                    else if current_phase == PHASE_DRAG && s.dragging then
                        if range > 0 && tw > 0 then
                            val tx0  = s.bounds.x + SLIDER_THUMB / 2
                            val rel0 = (input.mouse_x - tx0) * range / tw
                            val rel  = if rel0 < 0 then 0 else if rel0 > range then range else rel0
                            val v    = vmin + rel
                            if v != value then on_change(v) else 0
                            0
                        else 0
                    else if current_phase == PHASE_REL then
                        s.dragging = false
                        0
                    else 0
                _ -> 0
        SizedNode(s)  -> dispatch(s.child, input)
        CenterNode(s) -> dispatch(s.child, input)
        BoxNode(s)    -> dispatch(s.child, input)
        StackNode(s) ->
            var i = 0
            while i < len(s.children) do
                dispatch(s.children[i], input)
                i = i + 1
            0
        HStackNode(s) ->
            var i = 0
            while i < len(s.children) do
                dispatch(s.children[i], input)
                i = i + 1
            0
        PortalNode(s)          -> dispatch(s.child, input)
        AbsolutePositionNode(s) -> dispatch(s.child, input)
        BackdropNode(_)        -> 0
        ComponentNode(s)       -> dispatch(s.child, input)
        ContextProviderNode(s) -> dispatch(s.child, input)
        KeyedNode(s)           -> dispatch(s.child, input)
        _ -> 0

// True when every child is a Keyed wrapper. We only switch to the
// key-matched reconciliation path for fully-keyed lists; mixing keyed
// and unkeyed children is a programming bug, and falling through to
// positional matching keeps surprises minimal.
all_keyed(kids: []View) -> bool
    var ok = true
    var i = 0
    while ok && i < len(kids) do
        val is_keyed = kids[i] match
            Keyed(_, _) -> true
            _           -> false
        if !is_keyed then ok = false
        i = i + 1
    ok

key_of_view(v: View) -> int
    v match
        Keyed(k, _) -> k
        _           -> -1

key_of_node(n: Node) -> int
    n match
        KeyedNode(s) -> s.key
        _            -> -1

// Linear-scan key match. For each new child, find the unclaimed old
// child with the matching key (KeyedNode), reconcile it; if none,
// mount fresh. Old children that nobody claims are silently dropped.
// O(n*m) — fine for typical lists; promote to a hash map later.
reconcile_keyed_children(old_kids: []Node, new_kids: []View) -> []Node
    val n_new = len(new_kids)
    val n_old = len(old_kids)
    val out   = (new [n_new]Node)[:]
    val taken = (new [n_old]bool)[:]
    var k = 0
    while k < n_old do
        taken[k] = false
        k = k + 1
    var i = 0
    while i < n_new do
        val target = key_of_view(new_kids[i])
        var found = -1
        var j = 0
        while found < 0 && j < n_old do
            if !taken[j] && key_of_node(old_kids[j]) == target then
                found = j
            j = j + 1
        if found >= 0 then
            taken[found] = true
            out[i] = reconcile(old_kids[found], new_kids[i])
        else
            out[i] = mount(new_kids[i])
        i = i + 1
    out

// Positional fallback — the previous Stack reconcile policy.
reconcile_positional_children(old_kids: []Node, new_kids: []View) -> []Node
    val n_new = len(new_kids)
    val n_old = len(old_kids)
    if n_new == n_old then
        var i = 0
        while i < n_new do
            old_kids[i] = reconcile(old_kids[i], new_kids[i])
            i = i + 1
        old_kids
    else
        val out = (new [n_new]Node)[:]
        var i = 0
        while i < n_new do
            out[i] = mount(new_kids[i])
            i = i + 1
        out

reconcile_children(old_kids: []Node, new_kids: []View) -> []Node
    if len(new_kids) > 0 && all_keyed(new_kids) then
        reconcile_keyed_children(old_kids, new_kids)
    else
        reconcile_positional_children(old_kids, new_kids)

reconcile(old: Node, v: View) -> Node
    old match
        TextNode(state) ->
            v match
                Text(_) ->
                    state.view = v
                    old
                _ -> mount(v)
        ButtonNode(state) ->
            v match
                Button(_, _) ->
                    state.view = v
                    old
                _ -> mount(v)
        SpacerNode(state) ->
            v match
                Spacer(_) ->
                    state.view = v
                    old
                _ -> mount(v)
        ImageNode(state) ->
            v match
                Image(_, _, _) ->
                    state.view = v
                    old
                _ -> mount(v)
        CheckboxNode(state) ->
            v match
                Checkbox(_, _, _) ->
                    state.view = v
                    old
                _ -> mount(v)
        RadioNode(state) ->
            v match
                Radio(_, _, _) ->
                    state.view = v
                    old
                _ -> mount(v)
        SliderNode(state) ->
            v match
                Slider(_, _, _, _, _) ->
                    state.view = v
                    old
                _ -> mount(v)
        InputNode(state) ->
            v match
                Input(_, _, _, _) ->
                    state.view = v
                    old
                _ -> mount(v)
        SizedNode(state) ->
            v match
                Sized(c, _, _) ->
                    state.view  = v
                    state.child = reconcile(state.child, c)
                    old
                _ -> mount(v)
        CenterNode(state) ->
            v match
                Center(c) ->
                    state.view  = v
                    state.child = reconcile(state.child, c)
                    old
                _ -> mount(v)
        BoxNode(state) ->
            v match
                Box(c, _, _) ->
                    state.view  = v
                    state.child = reconcile(state.child, c)
                    old
                _ -> mount(v)
        StackNode(state) ->
            v match
                Stack(g, kids) ->
                    state.view = v
                    state.gap  = g
                    state.children = reconcile_children(state.children, kids)
                    old
                _ -> mount(v)
        HStackNode(state) ->
            v match
                HStack(g, kids) ->
                    state.view = v
                    state.gap  = g
                    state.children = reconcile_children(state.children, kids)
                    old
                _ -> mount(v)
        PortalNode(state) ->
            v match
                Portal(c) ->
                    state.view  = v
                    state.child = reconcile(state.child, c)
                    old
                _ -> mount(v)
        AbsolutePositionNode(state) ->
            v match
                AbsolutePosition(c, _, _, _, _) ->
                    state.view  = v
                    state.child = reconcile(state.child, c)
                    old
                _ -> mount(v)
        BackdropNode(state) ->
            v match
                Backdrop(_) ->
                    state.view = v
                    old
                _ -> mount(v)
        ComponentNode(state) ->
            v match
                Component(_) ->
                    // Update the view ref; do NOT call rerender(old) here.
                    // The caller of reconcile (rerender) walks the tree
                    // afterwards and re-runs every Component, so calling
                    // rerender from inside reconcile produced a double-
                    // render of nested Components.
                    state.view = v
                    old
                _ -> mount(v)
        ContextProviderNode(state) ->
            v match
                ContextProvider(key, value, child_view) ->
                    state.view = v
                    state.key = key
                    state.value = value
                    push_context(key, value)
                    state.child = reconcile(state.child, child_view)
                    pop_context()
                    old
                _ -> mount(v)
        KeyedNode(state) ->
            v match
                Keyed(key, child_view) ->
                    state.view = v
                    state.key = key
                    state.child = reconcile(state.child, child_view)
                    old
                _ -> mount(v)

// Drive a Component's re-render: hook cursor reset, render() called,
// the produced View is reconciled against the existing child Node.
// Also recurses into Stack and other wrappers so rerender() at the
// root re-runs every Component in the tree (single-pass dirty walk).
rerender(n: Node) -> int
    n match
        ComponentNode(s) ->
            s.view match
                Component(render_fn) ->
                    s.fiber.hook_index = 0
                    val root = render_fn(s.fiber)
                    s.child = reconcile(s.child, root)
                    rerender(s.child)
                    0
                _ -> 0
        StackNode(s) ->
            var i = 0
            while i < len(s.children) do
                rerender(s.children[i])
                i = i + 1
            0
        HStackNode(s) ->
            var i = 0
            while i < len(s.children) do
                rerender(s.children[i])
                i = i + 1
            0
        SizedNode(s)            -> rerender(s.child)
        CenterNode(s)           -> rerender(s.child)
        BoxNode(s)              -> rerender(s.child)
        PortalNode(s)           -> rerender(s.child)
        AbsolutePositionNode(s) -> rerender(s.child)
        ContextProviderNode(s) ->
            push_context(s.key, s.value)
            rerender(s.child)
            pop_context()
            0
        KeyedNode(s) -> rerender(s.child)
        _ -> 0

render(n: Node) -> int
    n match
        TextNode(s) ->
            s.view match
                Text(c) ->
                    host_draw_text(s.bounds.x, s.bounds.y + 14, c, 220, 220, 240, 255)
                    0
                _ -> 0
        ButtonNode(s) ->
            s.view match
                Button(l, _) ->
                    host_fill_rect(s.bounds.x, s.bounds.y, s.bounds.w, s.bounds.h, 40, 40, 55, 255)
                    host_draw_text(s.bounds.x + BTN_PAD_X, s.bounds.y + BTN_PAD_Y + 14, l, 220, 220, 240, 255)
                    0
                _ -> 0
        SpacerNode(_) -> 0
        ImageNode(s) ->
            s.view match
                Image(src, _, _) ->
                    host_draw_image(s.bounds.x, s.bounds.y, s.bounds.w, s.bounds.h, src)
                    0
                _ -> 0
        CheckboxNode(s) ->
            s.view match
                Checkbox(l, checked, _) ->
                    host_fill_rect(s.bounds.x, s.bounds.y, LINE_H, LINE_H, 60, 60, 80, 255)
                    if checked then
                        host_fill_rect(s.bounds.x + 4, s.bounds.y + 4, LINE_H - 8, LINE_H - 8, 220, 220, 240, 255)
                    host_draw_text(s.bounds.x + LINE_H + CHK_GAP, s.bounds.y + 14, l, 220, 220, 240, 255)
                    0
                _ -> 0
        RadioNode(s) ->
            // Drawn as a square ring (since fill_rect is the only shape
            // primitive); a real backend swaps these for circle ops.
            // Inner mark is centered (4px inset) when selected.
            s.view match
                Radio(l, selected, _) ->
                    host_fill_rect(s.bounds.x, s.bounds.y, LINE_H, LINE_H, 60, 60, 80, 255)
                    if selected then
                        host_fill_rect(s.bounds.x + 4, s.bounds.y + 4, LINE_H - 8, LINE_H - 8, 220, 220, 240, 255)
                    host_draw_text(s.bounds.x + LINE_H + RADIO_GAP, s.bounds.y + 14, l, 220, 220, 240, 255)
                    0
                _ -> 0
        InputNode(s) ->
            // Background fill (slightly lighter when focused, like the
            // Scala suit's input theme). Then the value (or placeholder
            // if the value is empty), drawn at the Input's standard
            // pad inset.
            s.view match
                Input(value, placeholder, _, _) ->
                    val bg_lit = if focused_id == s.focus_id then 80 else 60
                    host_fill_rect(s.bounds.x, s.bounds.y, s.bounds.w, s.bounds.h, bg_lit, bg_lit, 90, 255)
                    val shown = if len(value) > 0 then value else placeholder
                    val tx = s.bounds.x + INPUT_PAD_X
                    val ty = s.bounds.y + INPUT_PAD_Y + 14
                    host_draw_text(tx, ty, shown, 220, 220, 240, 255)
                    0
                _ -> 0
        SliderNode(s) ->
            // Track is a thin filled rect spanning the full bounds width;
            // thumb sits at the value's normalized position. Match the
            // dispatch math so a value emitted by a click renders the
            // thumb at exactly the click's x.
            s.view match
                Slider(value, vmin, vmax, _, _) ->
                    val track_y = s.bounds.y + (SLIDER_H - SLIDER_TRACK) / 2
                    host_fill_rect(s.bounds.x, track_y, s.bounds.w, SLIDER_TRACK, 60, 60, 80, 255)
                    val range = vmax - vmin
                    val tw    = s.bounds.w - SLIDER_THUMB
                    val rel   = if range > 0 && tw > 0 then (value - vmin) * tw / range else 0
                    val tx    = s.bounds.x + rel
                    host_fill_rect(tx, s.bounds.y, SLIDER_THUMB, SLIDER_H, 220, 220, 240, 255)
                    0
                _ -> 0
        SizedNode(s)  -> render(s.child)
        CenterNode(s) -> render(s.child)
        BoxNode(s) ->
            s.view match
                Box(_, c, _) ->
                    host_fill_rect(s.bounds.x, s.bounds.y, s.bounds.w, s.bounds.h, c.r, c.g, c.b, c.a)
                    render(s.child)
                    0
                _ -> render(s.child)
        StackNode(s) ->
            var i = 0
            while i < len(s.children) do
                render(s.children[i])
                i = i + 1
            0
        HStackNode(s) ->
            var i = 0
            while i < len(s.children) do
                render(s.children[i])
                i = i + 1
            0
        PortalNode(s) ->
            // Defer render to the overlay pass. Push the child node
            // (already laid out against screen_frame in layout()) and
            // rely on render_overlays() to drain after the main tree
            // has finished — that's what gets the Portal's content
            // drawn on top of everything else.
            push_overlay(s.child)
            0
        AbsolutePositionNode(s) -> render(s.child)
        BackdropNode(s) ->
            s.view match
                Backdrop(c) ->
                    host_fill_rect(s.bounds.x, s.bounds.y, s.bounds.w, s.bounds.h, c.r, c.g, c.b, c.a)
                    0
                _ -> 0
        ComponentNode(s)       -> render(s.child)
        ContextProviderNode(s) -> render(s.child)
        KeyedNode(s)           -> render(s.child)

// Drain the overlay queue. Called by run_loop after render(node) so
// portaled content draws on top of the main tree. Each frame builds
// a fresh queue — count is reset here so the next render() pass
// starts clean.
render_overlays() -> int
    ensure_overlay_init()
    var i = 0
    while i < overlay_count do
        render(overlay_queue[i])
        i = i + 1
    overlay_count = 0
    0

// run_loop drives the engine the way an app's main() would in
// production: drain events from the host, dispatch them through the
// tree, then rerender/layout/render/present once per frame. Returns
// the frame index at exit. `max_frames` lets tests bound the loop;
// pass a large constant for "run forever" — the loop still exits
// early on EVENT_QUIT.
//
// One InputState is reused across frames so a press-and-hold persists
// the mouse_pressed bit across multiple dispatches until the
// matching MOUSE_REL arrives. The engine doesn't yet do focus /
// pointer-capture; whichever ButtonNode contains the press point
// fires its on_click on each MOUSE_PRESS.
run_loop(node: Node, frame: Rect, max_frames: int) -> int
    val input = InputState(0, 0, false)
    var frame_idx = 0
    var quit = false
    // The screen frame is what Portals lay out their children
    // against. Set it once up front; if the host ever supports
    // resize, this would update on each frame.
    set_screen_frame(frame)
    // Initial layout so event hit-tests have valid bounds before the
    // first frame's render produces them.
    layout(node, frame)
    while !quit && frame_idx < max_frames do
        var tag = host_poll_event()
        while tag != EVENT_NONE && !quit do
            if tag == EVENT_QUIT then
                quit = true
            else if tag == EVENT_MOUSE_PRESS then
                input.mouse_x = host_event_x()
                input.mouse_y = host_event_y()
                input.mouse_pressed = true
                set_phase(PHASE_PRESS)
                dispatch(node, input)
                0
            else if tag == EVENT_MOUSE_REL then
                input.mouse_pressed = false
                set_phase(PHASE_REL)
                dispatch(node, input)
                set_phase(PHASE_PRESS)   // restore default for synthesized presses
                0
            else if tag == EVENT_MOUSE_MOVE then
                input.mouse_x = host_event_x()
                input.mouse_y = host_event_y()
                if input.mouse_pressed then
                    set_phase(PHASE_DRAG)
                    dispatch(node, input)
                    set_phase(PHASE_PRESS)
                    0
                else 0
            else if tag == EVENT_KEY_DOWN then
                set_key_event(host_event_key(), host_event_text())
                set_phase(PHASE_KEY)
                dispatch(node, input)
                set_phase(PHASE_PRESS)
                0
            else 0
            tag = host_poll_event()
        if !quit then
            rerender(node)
            layout(node, frame)
            render(node)
            render_overlays()
            host_present_frame()
            host_sleep_until_next_frame()
            0
        frame_idx = frame_idx + 1
    frame_idx
