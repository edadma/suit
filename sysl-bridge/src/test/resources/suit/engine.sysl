// suit engine — View/Node tree, layout, hit-test, dispatch, render.
// Lives in the same `module suit` as hooks.sysl so the engine can name
// the Fiber type without an import. The Component variant carries a
// `(Fiber) -> View` render function; mount/rerender drive that fiber.
//
// host_draw_text is the only OS-facing extern wired here — render() calls
// it to paint Text nodes. Demos register their own JVM/OS-side handler.

module suit

extern host_draw_text(x: int, y: int, text: string, r: int, g: int, b: int, a: int) -> int

// OS-facing event/render loop contract — implemented by the host (JVM
// dev shell, OS layer, or test stub). Tags are the int returned by
// host_poll_event; coords for the latest mouse event are read via
// host_event_x / host_event_y. host_now_ms is a monotonic ms clock
// for animations. host_present_frame flushes the draw buffer to the
// screen; host_sleep_until_next_frame paces to vsync.
extern host_poll_event() -> int
extern host_event_x() -> int
extern host_event_y() -> int
extern host_now_ms() -> int
extern host_present_frame() -> int
extern host_sleep_until_next_frame() -> int

const EVENT_NONE:        int = 0
const EVENT_QUIT:        int = 1
const EVENT_MOUSE_PRESS: int = 2
const EVENT_MOUSE_REL:   int = 3
const EVENT_MOUSE_MOVE:  int = 4
const EVENT_KEY_DOWN:    int = 5
const EVENT_KEY_UP:      int = 6
const EVENT_FRAME:       int = 7

struct Rect
    x: int
    y: int
    w: int
    h: int

struct InputState
    mouse_x: int
    mouse_y: int
    mouse_pressed: bool

enum View
    Text(content: string)
    Button(label: string, on_click: () -> int)
    Stack(children: []View)
    Component(render: (Fiber) -> View)
    ContextProvider(key: int, value: HookValue, child: View)
    Keyed(key: int, child: View)

struct TextNodeState
    view: View
    bounds: Rect

struct ButtonNodeState
    view: View
    bounds: Rect

struct StackNodeState
    view: View
    bounds: Rect
    children: []Node

struct ComponentNodeState
    view: View
    bounds: Rect
    fiber: Fiber
    child: Node

struct ContextProviderState
    view: View
    bounds: Rect
    key: int
    value: HookValue
    child: Node

struct KeyedNodeState
    view: View
    bounds: Rect
    key: int
    child: Node

enum Node
    TextNode(s: TextNodeState)
    ButtonNode(s: ButtonNodeState)
    StackNode(s: StackNodeState)
    ComponentNode(s: ComponentNodeState)
    ContextProviderNode(s: ContextProviderState)
    KeyedNode(s: KeyedNodeState)

// Module-level context stack — pushed when mount/rerender enters a
// ContextProvider's subtree, popped on the way back. use_context walks
// from top of stack down so nearest provider for a given key wins
// (matches React's nested-Provider shadowing).
const CONTEXT_STACK_CAPACITY: int = 32

struct ContextEntry
    key: int
    value: HookValue

var context_stack: []ContextEntry
var context_depth: int = 0
var context_initialized: bool = false

ensure_context_init() -> int
    if !context_initialized then
        context_stack = (new [CONTEXT_STACK_CAPACITY]ContextEntry)[:]
        context_initialized = true
        0
    else 0

push_context(key: int, value: HookValue) -> int
    ensure_context_init()
    context_stack[context_depth] = ContextEntry(key, value)
    context_depth = context_depth + 1
    0

pop_context() -> int
    context_depth = context_depth - 1
    0

read_context(key: int) -> HookValue
    var i = context_depth - 1
    while i >= 0 do
        if context_stack[i].key == key then
            return context_stack[i].value
        i = i - 1
    Empty

// use_context — looks up the nearest enclosing provider for `key`.
// Doesn't consume a hook cell index because it has no per-fiber state;
// safe to call zero or many times per render.
use_context(f: Fiber, key: int) -> HookValue
    read_context(key)

mount(v: View) -> Node
    v match
        Text(_)      -> TextNode(TextNodeState(v, Rect(0, 0, 0, 0)))
        Button(_, _) -> ButtonNode(ButtonNodeState(v, Rect(0, 0, 0, 0)))
        Stack(kids) ->
            val n = len(kids)
            val nodes = (new [n]Node)[:]
            var i = 0
            while i < n do
                nodes[i] = mount(kids[i])
                i = i + 1
            StackNode(StackNodeState(v, Rect(0, 0, 0, 0), nodes))
        Component(render_fn) ->
            val f = new_fiber()
            f.hook_index = 0
            val root = render_fn(f)
            ComponentNode(ComponentNodeState(v, Rect(0, 0, 0, 0), f, mount(root)))
        ContextProvider(key, value, child) ->
            push_context(key, value)
            val mounted_child = mount(child)
            pop_context()
            ContextProviderNode(ContextProviderState(v, Rect(0, 0, 0, 0), key, value, mounted_child))
        Keyed(key, child) ->
            KeyedNode(KeyedNodeState(v, Rect(0, 0, 0, 0), key, mount(child)))

set_rect(b: Rect, frame: Rect) -> int
    b.x = frame.x
    b.y = frame.y
    b.w = frame.w
    b.h = frame.h
    0

layout(n: Node, frame: Rect) -> int
    n match
        TextNode(s)   -> set_rect(s.bounds, frame)
        ButtonNode(s) -> set_rect(s.bounds, frame)
        StackNode(s) ->
            set_rect(s.bounds, frame)
            val n_kids = len(s.children)
            val each_h = frame.h / n_kids
            var pos = frame.y
            var i = 0
            while i < n_kids do
                layout(s.children[i], Rect(frame.x, pos, frame.w, each_h))
                pos = pos + each_h
                i = i + 1
            0
        ComponentNode(s) ->
            set_rect(s.bounds, frame)
            layout(s.child, frame)
        ContextProviderNode(s) ->
            set_rect(s.bounds, frame)
            layout(s.child, frame)
        KeyedNode(s) ->
            set_rect(s.bounds, frame)
            layout(s.child, frame)

contains(b: Rect, x: int, y: int) -> bool
    x >= b.x && x < b.x + b.w && y >= b.y && y < b.y + b.h

dispatch(n: Node, input: InputState) -> int
    n match
        ButtonNode(s) ->
            if input.mouse_pressed && contains(s.bounds, input.mouse_x, input.mouse_y) then
                s.view match
                    Button(_, on_click) ->
                        on_click()
                        0
                    _ -> 0
            else 0
        StackNode(s) ->
            var i = 0
            while i < len(s.children) do
                dispatch(s.children[i], input)
                i = i + 1
            0
        ComponentNode(s) -> dispatch(s.child, input)
        ContextProviderNode(s) -> dispatch(s.child, input)
        KeyedNode(s) -> dispatch(s.child, input)
        _ -> 0

// True when every child is a Keyed wrapper. We only switch to the
// key-matched reconciliation path for fully-keyed lists; mixing keyed
// and unkeyed children is a programming bug, and falling through to
// positional matching keeps surprises minimal.
all_keyed(kids: []View) -> bool
    var ok = true
    var i = 0
    while ok && i < len(kids) do
        val is_keyed = kids[i] match
            Keyed(_, _) -> true
            _           -> false
        if !is_keyed then ok = false
        i = i + 1
    ok

key_of_view(v: View) -> int
    v match
        Keyed(k, _) -> k
        _           -> -1

key_of_node(n: Node) -> int
    n match
        KeyedNode(s) -> s.key
        _            -> -1

// Linear-scan key match. For each new child, find the unclaimed old
// child with the matching key (KeyedNode), reconcile it; if none,
// mount fresh. Old children that nobody claims are silently dropped.
// O(n*m) — fine for typical lists; promote to a hash map later.
reconcile_keyed_children(old_kids: []Node, new_kids: []View) -> []Node
    val n_new = len(new_kids)
    val n_old = len(old_kids)
    val out   = (new [n_new]Node)[:]
    val taken = (new [n_old]bool)[:]
    var k = 0
    while k < n_old do
        taken[k] = false
        k = k + 1
    var i = 0
    while i < n_new do
        val target = key_of_view(new_kids[i])
        var found = -1
        var j = 0
        while found < 0 && j < n_old do
            if !taken[j] && key_of_node(old_kids[j]) == target then
                found = j
            j = j + 1
        if found >= 0 then
            taken[found] = true
            out[i] = reconcile(old_kids[found], new_kids[i])
        else
            out[i] = mount(new_kids[i])
        i = i + 1
    out

// Positional fallback — the previous Stack reconcile policy.
reconcile_positional_children(old_kids: []Node, new_kids: []View) -> []Node
    val n_new = len(new_kids)
    val n_old = len(old_kids)
    if n_new == n_old then
        var i = 0
        while i < n_new do
            old_kids[i] = reconcile(old_kids[i], new_kids[i])
            i = i + 1
        old_kids
    else
        val out = (new [n_new]Node)[:]
        var i = 0
        while i < n_new do
            out[i] = mount(new_kids[i])
            i = i + 1
        out

reconcile_children(old_kids: []Node, new_kids: []View) -> []Node
    if len(new_kids) > 0 && all_keyed(new_kids) then
        reconcile_keyed_children(old_kids, new_kids)
    else
        reconcile_positional_children(old_kids, new_kids)

reconcile(old: Node, v: View) -> Node
    old match
        TextNode(state) ->
            v match
                Text(_) ->
                    state.view = v
                    old
                _ -> mount(v)
        ButtonNode(state) ->
            v match
                Button(_, _) ->
                    state.view = v
                    old
                _ -> mount(v)
        StackNode(state) ->
            v match
                Stack(kids) ->
                    state.view = v
                    state.children = reconcile_children(state.children, kids)
                    old
                _ -> mount(v)
        ComponentNode(state) ->
            v match
                Component(_) ->
                    // Update the view ref; do NOT call rerender(old) here.
                    // The caller of reconcile (rerender) walks the tree
                    // afterwards and re-runs every Component, so calling
                    // rerender from inside reconcile produced a double-
                    // render of nested Components.
                    state.view = v
                    old
                _ -> mount(v)
        ContextProviderNode(state) ->
            v match
                ContextProvider(key, value, child_view) ->
                    state.view = v
                    state.key = key
                    state.value = value
                    push_context(key, value)
                    state.child = reconcile(state.child, child_view)
                    pop_context()
                    old
                _ -> mount(v)
        KeyedNode(state) ->
            v match
                Keyed(key, child_view) ->
                    state.view = v
                    state.key = key
                    state.child = reconcile(state.child, child_view)
                    old
                _ -> mount(v)

// Drive a Component's re-render: hook cursor reset, render() called,
// the produced View is reconciled against the existing child Node.
// Also recurses into Stack and other wrappers so rerender() at the
// root re-runs every Component in the tree (single-pass dirty walk).
rerender(n: Node) -> int
    n match
        ComponentNode(s) ->
            s.view match
                Component(render_fn) ->
                    s.fiber.hook_index = 0
                    val root = render_fn(s.fiber)
                    s.child = reconcile(s.child, root)
                    rerender(s.child)
                    0
                _ -> 0
        StackNode(s) ->
            var i = 0
            while i < len(s.children) do
                rerender(s.children[i])
                i = i + 1
            0
        ContextProviderNode(s) ->
            push_context(s.key, s.value)
            rerender(s.child)
            pop_context()
            0
        KeyedNode(s) -> rerender(s.child)
        _ -> 0

render(n: Node) -> int
    n match
        TextNode(s) ->
            s.view match
                Text(c) ->
                    host_draw_text(s.bounds.x, s.bounds.y, c, 220, 220, 240, 255)
                    0
                _ -> 0
        ButtonNode(_) -> 0
        StackNode(s) ->
            var i = 0
            while i < len(s.children) do
                render(s.children[i])
                i = i + 1
            0
        ComponentNode(s) -> render(s.child)
        ContextProviderNode(s) -> render(s.child)
        KeyedNode(s) -> render(s.child)

// run_loop drives the engine the way an app's main() would in
// production: drain events from the host, dispatch them through the
// tree, then rerender/layout/render/present once per frame. Returns
// the frame index at exit. `max_frames` lets tests bound the loop;
// pass a large constant for "run forever" — the loop still exits
// early on EVENT_QUIT.
//
// One InputState is reused across frames so a press-and-hold persists
// the mouse_pressed bit across multiple dispatches until the
// matching MOUSE_REL arrives. The engine doesn't yet do focus /
// pointer-capture; whichever ButtonNode contains the press point
// fires its on_click on each MOUSE_PRESS.
run_loop(node: Node, frame: Rect, max_frames: int) -> int
    val input = InputState(0, 0, false)
    var frame_idx = 0
    var quit = false
    // Initial layout so event hit-tests have valid bounds before the
    // first frame's render produces them.
    layout(node, frame)
    while !quit && frame_idx < max_frames do
        var tag = host_poll_event()
        while tag != EVENT_NONE && !quit do
            if tag == EVENT_QUIT then
                quit = true
            else if tag == EVENT_MOUSE_PRESS then
                input.mouse_x = host_event_x()
                input.mouse_y = host_event_y()
                input.mouse_pressed = true
                dispatch(node, input)
                0
            else if tag == EVENT_MOUSE_REL then
                input.mouse_pressed = false
                0
            else if tag == EVENT_MOUSE_MOVE then
                input.mouse_x = host_event_x()
                input.mouse_y = host_event_y()
                0
            else 0
            tag = host_poll_event()
        if !quit then
            rerender(node)
            layout(node, frame)
            render(node)
            host_present_frame()
            host_sleep_until_next_frame()
            0
        frame_idx = frame_idx + 1
    frame_idx
