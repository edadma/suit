// Positional hooks — module half that's standalone (no engine import).
// Owns HookValue, the per-fiber cell array, and the use_* primitives.
//
// `next_fiber_id` is the module's only mutable state; new_fiber bumps it
// so each Component instance gets a stable id useful for useId.
//
// Multi-file-module rule (see feedback memory): module-level vars cannot
// be re-exported as mutable to siblings. Keeping all writers (new_fiber)
// inside this same file means the engine can hold a Fiber typed value
// but never reaches in to mutate next_fiber_id directly.

module suit

// Extern re-declared here (canonical home is suit/engine.sysl) so
// use_transition can read the monotonic clock without the cross-file
// analyzer having to see engine.sysl first. Multiple `extern` decls
// of the same symbol are linker-compatible — they resolve to the
// single host-side registration.
extern host_now_ms() -> int

struct EffectState
    deps_hash: int

// Mutable int container backing useRef(int). Heap-allocated so each
// IntRef survives across renders and the user can write `ref.current`
// without triggering a re-render. Wrapped in a RefIntCell variant so
// the same fiber cell array can hold any hook flavor positionally.
struct IntRef
    current: int

// use_transition state. start_value + start_ms + duration_ms describe
// the active animation; target_value is checked each call so changes
// kick off a fresh segment. Eased value is recomputed from these
// fields on every render rather than stored — that way every frame's
// rerender naturally advances the animation against host_now_ms.
struct TransitionState
    start_value: int
    target_value: int
    start_ms: int
    duration_ms: int

enum HookValue
    Empty
    IntCell(v: int)
    BoolCell(v: bool)
    StringCell(v: string)
    EffectCell(s: EffectState)
    IdCell(id: string)
    RefIntCell(r: IntRef)
    TransitionCell(t: TransitionState)

struct Fiber
    cells: []HookValue
    cell_count: int
    hook_index: int
    fiber_id: int

const HOOK_CAPACITY: int = 16

var next_fiber_id: int = 0

new_fiber() -> Fiber
    next_fiber_id = next_fiber_id + 1
    val cells = (new [HOOK_CAPACITY]HookValue)[:]
    var i = 0
    while i < HOOK_CAPACITY do
        cells[i] = Empty
        i = i + 1
    Fiber(cells, 0, 0, next_fiber_id)

// useState(int) — most-used flavor; cell is IntCell, setter writes back.
use_state_int(f: Fiber, initial: int) -> (int, (int) -> int)
    val i = f.hook_index
    f.hook_index = i + 1
    val cell = f.cells[i]
    val current = cell match
        IntCell(v) -> v
        Empty ->
            f.cells[i] = IntCell(initial)
            initial
        _ -> initial
    setter = (next: int) ->
        f.cells[i] = IntCell(next)
        next
    return current, setter

// useState(bool) — used for toggles, Checkbox state, modal-open flags.
use_state_bool(f: Fiber, initial: bool) -> (bool, (bool) -> int)
    val i = f.hook_index
    f.hook_index = i + 1
    val cell = f.cells[i]
    val current = cell match
        BoolCell(v) -> v
        Empty ->
            f.cells[i] = BoolCell(initial)
            initial
        _ -> initial
    setter = (next: bool) ->
        f.cells[i] = BoolCell(next)
        0
    return current, setter

// useState(string) — used for Input.value, Dropdown selection.
use_state_string(f: Fiber, initial: string) -> (string, (string) -> int)
    val i = f.hook_index
    f.hook_index = i + 1
    val cell = f.cells[i]
    val current = cell match
        StringCell(v) -> v
        Empty ->
            f.cells[i] = StringCell(initial)
            initial
        _ -> initial
    setter = (next: string) ->
        f.cells[i] = StringCell(next)
        0
    return current, setter

// useEffect(setup, deps_hash) — runs `setup` on mount and whenever
// deps_hash differs from the value stored last render. No cleanup
// support yet (a future variant adds `() -> () -> int` and tracks the
// returned cleanup closure for unmount + dep-change ordering).
use_effect(f: Fiber, setup: () -> int, deps_hash: int) -> int
    val i = f.hook_index
    f.hook_index = i + 1
    val cell = f.cells[i]
    cell match
        EffectCell(s) ->
            if s.deps_hash != deps_hash then
                setup()
                s.deps_hash = deps_hash
            0
        Empty ->
            setup()
            f.cells[i] = EffectCell(EffectState(deps_hash))
            0
        _ -> 0

// useReducer(int) — Redux-style state hook. Reuses IntCell (same
// storage as use_state_int), but the dispatch closure reads the cell
// fresh on every call so successive dispatches in the same render see
// the previous dispatch's update. That fixes the "stale closure"
// hazard that bites when several actions are fired before the next
// render. Reducer is `(state, action) -> next_state`, both ints.
use_reducer_int(f: Fiber, reducer: (int, int) -> int, initial: int) -> (int, (int) -> int)
    val i = f.hook_index
    f.hook_index = i + 1
    val cell = f.cells[i]
    val current = cell match
        IntCell(v) -> v
        Empty ->
            f.cells[i] = IntCell(initial)
            initial
        _ -> initial
    dispatch = (action: int) ->
        val cur = f.cells[i] match
            IntCell(v) -> v
            _ -> initial
        val next = reducer(cur, action)
        f.cells[i] = IntCell(next)
        next
    return current, dispatch

// useRef(int) — returns an IntRef the component can mutate without
// triggering a re-render. The struct is allocated once on the first
// call (Empty cell) and reused thereafter (RefIntCell carries the
// same heap pointer across all renders for this fiber slot).
use_ref_int(f: Fiber, initial: int) -> IntRef
    val i = f.hook_index
    f.hook_index = i + 1
    val cell = f.cells[i]
    cell match
        RefIntCell(r) -> r
        Empty ->
            val r = IntRef(initial)
            f.cells[i] = RefIntCell(r)
            r
        _ -> IntRef(initial)

// useId — returns a stable string keyed on (fiber_id, cell_index).
// Survives across renders because the cell is initialized once and read
// thereafter. Used by form labels (`<label for="id-3-2">`-shape).
use_id(f: Fiber) -> string
    val i = f.hook_index
    f.hook_index = i + 1
    val cell = f.cells[i]
    cell match
        IdCell(id) -> id
        Empty ->
            val fid = f.fiber_id
            val id = s"id-$fid-$i"
            f.cells[i] = IdCell(id)
            id
        _ -> "?"

// Linear interpolation, clamped at both ends. duration_ms must be > 0;
// callers pass at least 1 to avoid division-by-zero.
ease_linear(start: int, target: int, start_ms: int, now_ms: int, duration_ms: int) -> int
    val elapsed = now_ms - start_ms
    if elapsed >= duration_ms then target
    else if elapsed <= 0 then start
    else start + (target - start) * elapsed / duration_ms

// use_transition — eased animation hook. Returns the current eased
// value of an animation toward `target` over `duration_ms`. When the
// caller passes a different target than the cell's stored target, a
// fresh segment is started from the currently-eased value.
//
// No separate tick function is needed: run_loop rerenders every
// frame, so each render call recomputes the eased value against
// host_now_ms. The animation "advances" implicitly via the rerender
// cycle. A future dirty-bit scheduler will need a tick_animations
// helper here to mark transitioning Components dirty.
use_transition(f: Fiber, target: int, duration_ms: int) -> int
    val i = f.hook_index
    f.hook_index = i + 1
    val cell = f.cells[i]
    val now = host_now_ms()
    cell match
        TransitionCell(s) ->
            if s.target_value != target then
                val current = ease_linear(s.start_value, s.target_value, s.start_ms, now, s.duration_ms)
                s.start_value = current
                s.target_value = target
                s.start_ms = now
                s.duration_ms = duration_ms
                current
            else
                ease_linear(s.start_value, s.target_value, s.start_ms, now, s.duration_ms)
        Empty ->
            f.cells[i] = TransitionCell(TransitionState(target, target, now, duration_ms))
            target
        _ -> target
