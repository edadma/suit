// Scope 2 finale — a Counter built entirely in sysl using a function
// component + use_state. The sysl engine mounts the Component, runs its
// render function with the fiber, reconciles the resulting View tree,
// lays it out, and renders. Clicking the "+" button fires a closure
// that captures the render-time `n`, calls the setter, and triggers a
// fresh render — the displayed Text changes accordingly.
//
// Phase α refactor: the engine + hooks now live in `module suit`.
// This file is just the demo — Counter component plus a driver that
// wires two independent Counters in a Stack and clicks them.

import suit.{Rect, InputState, View, Text, Button, Stack, Component, Node, Fiber}
import suit.{mount, layout, dispatch, rerender, render}
import suit.{use_state_int}

counter(f: Fiber) -> View
    val n, set_n = use_state_int(f, 0)
    on_inc = () ->
        set_n(n + 1)
        0
    val kids = (new [2]View)[:]
    kids[0] = Text(s"$n")
    kids[1] = Button("+", on_inc)
    Stack(kids)

// Two independent Counter children at positions 0 and 1 of a Stack.
// Each gets its own Fiber via mount; clicking inside one Counter's
// button must not perturb the other's state. Layout: Stack of 2
// Counters fills 200×160 → each gets 80 tall. Inside each Counter,
// Stack of 2 → Text 0..40, Button 40..80 (relative to the Counter's
// frame).
//
//   Counter A (y 0..80):    Text@0..40,  Button@40..80
//   Counter B (y 80..160):  Text@80..120, Button@120..160
//
// dispatch(InputState(50, 60, true))  hits A; (50, 140, true) hits B.
// Click sequence: A, A, B, A, B → A=3, B=2 → Texts emitted "0" "0",
// then "1" "0", "2" "0", "2" "1", "3" "1", "3" "2".

main() -> int
    val kids = (new [2]View)[:]
    kids[0] = Component(counter)
    kids[1] = Component(counter)
    val app = Stack(kids)
    val node = mount(app)

    layout(node, Rect(0, 0, 200, 160))
    render(node)                                        // "0", "0"

    dispatch(node, InputState(50, 60, true))            // click A
    rerender(node)
    layout(node, Rect(0, 0, 200, 160))
    render(node)                                        // "1", "0"

    dispatch(node, InputState(50, 60, true))            // click A
    rerender(node)
    layout(node, Rect(0, 0, 200, 160))
    render(node)                                        // "2", "0"

    dispatch(node, InputState(50, 140, true))           // click B
    rerender(node)
    layout(node, Rect(0, 0, 200, 160))
    render(node)                                        // "2", "1"

    dispatch(node, InputState(50, 60, true))            // click A
    rerender(node)
    layout(node, Rect(0, 0, 200, 160))
    render(node)                                        // "3", "1"

    dispatch(node, InputState(50, 140, true))           // click B
    rerender(node)
    layout(node, Rect(0, 0, 200, 160))
    render(node)                                        // "3", "2"
    0
