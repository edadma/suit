// Keyed reordering — verifies that swapping two Keyed children
// preserves each child Component's per-fiber state.
//
// Each item Component owns a counter cell that starts at its captured
// id (via use_state_int(initial=id)). Outer controller keeps a `swap`
// boolean. While swap=false the children are [Keyed(1, ItemA),
// Keyed(2, ItemB)]; while swap=true they're [Keyed(2, ItemB),
// Keyed(1, ItemA)]. Each item Component publishes its counter on
// every render.
//
// Frames driven by main():
//   render 0: mount, publishes [1, 2]   (initial state per item)
//   click on item-1's button (y=20) → its counter goes 1→11 (we
//     bump by 10 to make ordering observable). publish [11, 2].
//   click on item-2's button (y=60) → its counter goes 2→12. publish
//     [11, 12].
//   click swap-button (y=100) → swap=true → publish [12, 11] (item-2
//     first, item-1 second; both kept their state).
//
// If keyed reconcile is wrong, after the swap we'd see the items'
// state mixed up (positional reconcile would keep state at slot 0 in
// place even though the view at slot 0 is now Item B by id).

import suit.{View, Text, Button, Stack, Component, Keyed, Fiber, Rect, InputState}
import suit.{mount, layout, dispatch, rerender, render}
import suit.{use_state_int, use_state_bool}

extern host_publish(n: int) -> int
extern host_draw_text(x: int, y: int, text: string, r: int, g: int, b: int, a: int) -> int

// Item Component factory. Captures the id so its setter knows what
// initial value to seed the cell with on first mount.
make_item(id: int) -> View
    item_render = (f: Fiber) ->
        val n, set_n = use_state_int(f, id)
        host_publish(n)
        on_bump = () ->
            set_n(n + 10)
            0
        val kids = (new [2]View)[:]
        kids[0] = Text(s"$n")
        kids[1] = Button("+", on_bump)
        Stack(0, kids)
    Component(item_render)

controller(f: Fiber) -> View
    val swap, set_swap = use_state_bool(f, false)
    on_swap = () ->
        set_swap(!swap)
        0
    val item_a = make_item(1)
    val item_b = make_item(2)
    val items = (new [2]View)[:]
    if swap then
        items[0] = Keyed(2, item_b)
        items[1] = Keyed(1, item_a)
    else
        items[0] = Keyed(1, item_a)
        items[1] = Keyed(2, item_b)
    val outer = (new [2]View)[:]
    outer[0] = Stack(0, items)
    outer[1] = Button("swap", on_swap)
    Stack(0, outer)

// Layout: 200×120 outer Stack of [items_stack, swap-button].
// With measured-height layout each item Component naturally measures
// 48 tall (Text 18 + Button 30); the items_stack sums to 96, and the
// swap-button measures 30 (label="swap", h=LINE_H+2*BTN_PAD_Y). Frame
// leftover is unused (no Spacer flex). Concretely:
//   items_stack at y 0..96 (within the 200×96 sub-frame given to it):
//     Item 0 at y  0..48 — Text  0..18, Button 18..48
//     Item 1 at y 48..96 — Text 48..66, Button 66..96
//   swap-button at y 96..126 (overruns frame.h=120 but that's OK —
//     the overflow just clips off the bottom).
//
// Click coords:
//   (50,  30) → item 0's bump button (y 18..48)
//   (50,  80) → item 1's bump button (y 66..96)
//   (50, 110) → swap button (y 96..126)

main() -> int
    val app = Component(controller)
    val node = mount(app)
    layout(node, Rect(0, 0, 200, 120))
    render(node)                                // publish [1, 2]

    dispatch(node, InputState(50, 30, true))    // bump item 0
    rerender(node)
    layout(node, Rect(0, 0, 200, 120))
    render(node)                                // publish [11, 2]

    dispatch(node, InputState(50, 80, true))    // bump item 1
    rerender(node)
    layout(node, Rect(0, 0, 200, 120))
    render(node)                                // publish [11, 12]

    dispatch(node, InputState(50, 110, true))   // swap
    rerender(node)
    layout(node, Rect(0, 0, 200, 120))
    render(node)                                // publish [12, 11]
    0
