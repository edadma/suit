// Hook-flavors fixture — exercises useState(int), useState(bool),
// useId, and useEffect through a single Component (`fancy_counter`).
// The effect logs whenever its deps change; the test verifies each
// render's deps_hash difference produces exactly one effect call.
//
// Phase α refactor: engine + hooks live in `module suit`. This file is
// only the demo + driver, importing what it uses by name.

import suit.{View, Text, Button, Stack, Component, Fiber, Rect, InputState}
import suit.{mount, layout, dispatch, rerender, render}
import suit.{use_state_int, use_state_bool, use_id, use_effect}

extern host_record(s: string) -> int

// fancy_counter — exercises useState/useEffect/useId together.
//
// Hooks called per render (positional, hook_index advances by one each
// call):
//   1. useState(int) for `n`     — increments on Button "+"
//   2. useState(bool) for `on`   — toggles on Button "T"
//   3. useId()                   — stable id-1-2 across renders
//   4. useEffect with deps_hash  — fires on mount + when (n,on) changes
// The effect logs `s"effect[$id]: n=$n on=$on"` via host_record so the
// test can verify exact call counts and ordering.

fancy_counter(f: Fiber) -> View
    val n, set_n   = use_state_int(f, 0)
    val on, set_on = use_state_bool(f, false)
    val id         = use_id(f)
    // Layered into a single int: low bits = n; bit 30 = on. Works for
    // small n. Real impl would use a proper hash combiner.
    val deps_hash = n + (if on then 1073741824 else 0)
    log_effect = () ->
        host_record(s"effect[$id]: n=$n on=$on")
        0
    use_effect(f, log_effect, deps_hash)

    on_inc = () ->
        set_n(n + 1)
        0
    on_toggle = () ->
        set_on(!on)
        0

    val kids = (new [3]View)[:]
    kids[0] = Text(s"$n - $on")
    kids[1] = Button("+", on_inc, true)
    kids[2] = Button("T", on_toggle, true)
    Stack(0, kids)

// Driver: a single fancy_counter, click +, +, T, +.
// With measured-height layout the inner Stack(0, [Text, "+", "T"])
// places children at their natural heights:
//   Text   y= 0..18  (h=LINE_H)
//   "+"    y=18..48  (h=LINE_H + 2*BTN_PAD_Y)
//   "T"    y=48..78
// The remaining 200×42 below row "T" stays unused (no flex Spacer).
// Effect fires on mount (n=0,on=false), then once per state-change
// render (deps differ each time). 5 effect log lines total.

main() -> int
    val app = Component(fancy_counter)
    val node = mount(app)

    layout(node, Rect(0, 0, 200, 120))
    render(node)

    dispatch(node, InputState(50, 30, true))     // +
    rerender(node)
    layout(node, Rect(0, 0, 200, 120))
    render(node)

    dispatch(node, InputState(50, 30, true))     // +
    rerender(node)
    layout(node, Rect(0, 0, 200, 120))
    render(node)

    dispatch(node, InputState(50, 60, true))     // toggle
    rerender(node)
    layout(node, Rect(0, 0, 200, 120))
    render(node)

    dispatch(node, InputState(50, 30, true))     // +
    rerender(node)
    layout(node, Rect(0, 0, 200, 120))
    render(node)
    0
