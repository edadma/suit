// Hook-flavors fixture: a single Component exercises useState(int),
// useState(bool), useId, and useEffect. The effect logs whenever its
// deps change; the test verifies each render's deps_hash difference
// produces exactly one effect call. Clone of engine-counter.sysl with
// fancy_counter as the demo component and main() driving a click
// sequence that toggles each piece of state independently.

extern host_draw_text(x: int, y: int, text: string, r: int, g: int, b: int, a: int) -> int
extern host_record(s: string) -> int

struct Rect
    x: int
    y: int
    w: int
    h: int

struct InputState
    mouse_x: int
    mouse_y: int
    mouse_pressed: bool

// Hook cell payload. Each HookValue variant is one positional cell in a
// fiber's hook array. EffectState is wrapped in a struct so its mutable
// `deps_hash` field can be assigned through the match-arm binding (sysl
// allows field assignment on StructType, not on raw enum-variant binds).
struct EffectState
    deps_hash: int

enum HookValue
    Empty
    IntCell(v: int)
    BoolCell(v: bool)
    StringCell(v: string)
    EffectCell(s: EffectState)
    IdCell(id: string)

struct Fiber
    cells: []HookValue
    cell_count: int
    hook_index: int
    fiber_id: int

enum View
    Text(content: string)
    Button(label: string, on_click: () -> int)
    Stack(children: []View)
    Component(render: (Fiber) -> View)

struct TextNodeState
    view: View
    bounds: Rect

struct ButtonNodeState
    view: View
    bounds: Rect

struct StackNodeState
    view: View
    bounds: Rect
    children: []Node

struct ComponentNodeState
    view: View
    bounds: Rect
    fiber: Fiber
    child: Node

enum Node
    TextNode(s: TextNodeState)
    ButtonNode(s: ButtonNodeState)
    StackNode(s: StackNodeState)
    ComponentNode(s: ComponentNodeState)

const HOOK_CAPACITY: int = 16

var next_fiber_id: int = 0

new_fiber() -> Fiber
    next_fiber_id = next_fiber_id + 1
    val cells = (new [HOOK_CAPACITY]HookValue)[:]
    var i = 0
    while i < HOOK_CAPACITY do
        cells[i] = Empty
        i = i + 1
    Fiber(cells, 0, 0, next_fiber_id)

// useState(int) — most-used flavor; cell is IntCell, setter writes back.
use_state_int(f: Fiber, initial: int) -> (int, (int) -> int)
    val i = f.hook_index
    f.hook_index = i + 1
    val cell = f.cells[i]
    val current = cell match
        IntCell(v) -> v
        Empty ->
            f.cells[i] = IntCell(initial)
            initial
        _ -> initial
    setter = (next: int) ->
        f.cells[i] = IntCell(next)
        next
    return current, setter

// useState(bool) — used for toggles, Checkbox state, modal-open flags.
use_state_bool(f: Fiber, initial: bool) -> (bool, (bool) -> int)
    val i = f.hook_index
    f.hook_index = i + 1
    val cell = f.cells[i]
    val current = cell match
        BoolCell(v) -> v
        Empty ->
            f.cells[i] = BoolCell(initial)
            initial
        _ -> initial
    setter = (next: bool) ->
        f.cells[i] = BoolCell(next)
        0
    return current, setter

// useState(string) — used for Input.value, Dropdown selection.
use_state_string(f: Fiber, initial: string) -> (string, (string) -> int)
    val i = f.hook_index
    f.hook_index = i + 1
    val cell = f.cells[i]
    val current = cell match
        StringCell(v) -> v
        Empty ->
            f.cells[i] = StringCell(initial)
            initial
        _ -> initial
    setter = (next: string) ->
        f.cells[i] = StringCell(next)
        0
    return current, setter

// useEffect(setup, deps_hash) — runs `setup` on mount and whenever
// deps_hash differs from the value stored last render. No cleanup
// support yet (a future variant adds `() -> () -> int` and tracks the
// returned cleanup closure for unmount + dep-change ordering).
use_effect(f: Fiber, setup: () -> int, deps_hash: int) -> int
    val i = f.hook_index
    f.hook_index = i + 1
    val cell = f.cells[i]
    cell match
        EffectCell(s) ->
            if s.deps_hash != deps_hash then
                setup()
                s.deps_hash = deps_hash
            0
        Empty ->
            setup()
            f.cells[i] = EffectCell(EffectState(deps_hash))
            0
        _ -> 0

// useId — returns a stable string keyed on (fiber_id, cell_index).
// Survives across renders because the cell is initialized once and read
// thereafter. Used by form labels (`<label for="id-3-2">`-shape).
use_id(f: Fiber) -> string
    val i = f.hook_index
    f.hook_index = i + 1
    val cell = f.cells[i]
    cell match
        IdCell(id) -> id
        Empty ->
            val fid = f.fiber_id
            val id = s"id-$fid-$i"
            f.cells[i] = IdCell(id)
            id
        _ -> "?"

// ---- engine -------------------------------------------------------------

mount(v: View) -> Node
    v match
        Text(_)      -> TextNode(TextNodeState(v, Rect(0, 0, 0, 0)))
        Button(_, _) -> ButtonNode(ButtonNodeState(v, Rect(0, 0, 0, 0)))
        Stack(kids) ->
            val n = len(kids)
            val nodes = (new [n]Node)[:]
            var i = 0
            while i < n do
                nodes[i] = mount(kids[i])
                i = i + 1
            StackNode(StackNodeState(v, Rect(0, 0, 0, 0), nodes))
        Component(render) ->
            val f = new_fiber()
            f.hook_index = 0
            val root = render(f)
            ComponentNode(ComponentNodeState(v, Rect(0, 0, 0, 0), f, mount(root)))

set_rect(b: Rect, frame: Rect) -> int
    b.x = frame.x
    b.y = frame.y
    b.w = frame.w
    b.h = frame.h
    0

layout(n: Node, frame: Rect) -> int
    n match
        TextNode(s)   -> set_rect(s.bounds, frame)
        ButtonNode(s) -> set_rect(s.bounds, frame)
        StackNode(s) ->
            set_rect(s.bounds, frame)
            val n_kids = len(s.children)
            val each_h = frame.h / n_kids
            var pos = frame.y
            var i = 0
            while i < n_kids do
                layout(s.children[i], Rect(frame.x, pos, frame.w, each_h))
                pos = pos + each_h
                i = i + 1
            0
        ComponentNode(s) ->
            set_rect(s.bounds, frame)
            layout(s.child, frame)

contains(b: Rect, x: int, y: int) -> bool
    x >= b.x && x < b.x + b.w && y >= b.y && y < b.y + b.h

dispatch(n: Node, input: InputState) -> int
    n match
        ButtonNode(s) ->
            if input.mouse_pressed && contains(s.bounds, input.mouse_x, input.mouse_y) then
                s.view match
                    Button(_, on_click) ->
                        on_click()
                        0
                    _ -> 0
            else 0
        StackNode(s) ->
            var i = 0
            while i < len(s.children) do
                dispatch(s.children[i], input)
                i = i + 1
            0
        ComponentNode(s) -> dispatch(s.child, input)
        _ -> 0

reconcile(old: Node, v: View) -> Node
    old match
        TextNode(state) ->
            v match
                Text(_) ->
                    state.view = v
                    old
                _ -> mount(v)
        ButtonNode(state) ->
            v match
                Button(_, _) ->
                    state.view = v
                    old
                _ -> mount(v)
        StackNode(state) ->
            v match
                Stack(kids) ->
                    if len(kids) == len(state.children) then
                        state.view = v
                        var i = 0
                        while i < len(kids) do
                            state.children[i] = reconcile(state.children[i], kids[i])
                            i = i + 1
                        old
                    else mount(v)
                _ -> mount(v)
        ComponentNode(state) ->
            v match
                Component(_) ->
                    state.view = v
                    rerender(old)
                    old
                _ -> mount(v)

// Drive a Component's re-render: hook cursor reset, render() called,
// the produced View is reconciled against the existing child Node.
// Also recurses into Stack and other wrappers so rerender() at the
// root re-runs every Component in the tree (single-pass dirty walk).
rerender(n: Node) -> int
    n match
        ComponentNode(s) ->
            s.view match
                Component(render) ->
                    s.fiber.hook_index = 0
                    val root = render(s.fiber)
                    s.child = reconcile(s.child, root)
                    rerender(s.child)
                    0
                _ -> 0
        StackNode(s) ->
            var i = 0
            while i < len(s.children) do
                rerender(s.children[i])
                i = i + 1
            0
        _ -> 0

render(n: Node) -> int
    n match
        TextNode(s) ->
            s.view match
                Text(c) ->
                    host_draw_text(s.bounds.x, s.bounds.y, c, 220, 220, 240, 255)
                    0
                _ -> 0
        ButtonNode(_) -> 0
        StackNode(s) ->
            var i = 0
            while i < len(s.children) do
                render(s.children[i])
                i = i + 1
            0
        ComponentNode(s) -> render(s.child)

// ---- fancy_counter — exercises useState/useEffect/useId together --------
//
// Hooks called per render (positional, hook_index advances by one each
// call):
//   1. useState(int) for `n`     — increments on Button "+"
//   2. useState(bool) for `on`   — toggles on Button "T"
//   3. useId()                   — stable id-1-2 across renders
//   4. useEffect with deps_hash  — fires on mount + when (n,on) changes
// The effect logs `s"effect[$id]: n=$n on=$on"` via host_record so the
// test can verify exact call counts and ordering.

fancy_counter(f: Fiber) -> View
    val n, set_n   = use_state_int(f, 0)
    val on, set_on = use_state_bool(f, false)
    val id         = use_id(f)
    // Layered into a single int: low bits = n; bit 30 = on. Works for
    // small n. Real impl would use a proper hash combiner.
    val deps_hash = n + (if on then 1073741824 else 0)
    log_effect = () ->
        host_record(s"effect[$id]: n=$n on=$on")
        0
    use_effect(f, log_effect, deps_hash)

    on_inc = () ->
        set_n(n + 1)
        0
    on_toggle = () ->
        set_on(!on)
        0

    val kids = (new [3]View)[:]
    kids[0] = Text(s"$n - $on")
    kids[1] = Button("+", on_inc)
    kids[2] = Button("T", on_toggle)
    Stack(kids)

// ---- driver: a single fancy_counter, click +, +, T, + ------------------
//
// Layout: 200×120, single child Stack with 3 children → 40 each.
//   Text   y= 0..40
//   "+"    y=40..80
//   "T"    y=80..120
//
// Inputs:
//   click "+"  at y= 60  → n: 0→1
//   click "+"  at y= 60  → n: 1→2
//   click "T"  at y=100  → on: false→true
//   click "+"  at y= 60  → n: 2→3
// Effect fires on mount (n=0,on=false), then once per state-change render
// (deps differ each time). 5 effect log lines total.

main() -> int
    val app = Component(fancy_counter)
    val node = mount(app)

    layout(node, Rect(0, 0, 200, 120))
    render(node)

    dispatch(node, InputState(50, 60, true))     // +
    rerender(node)
    layout(node, Rect(0, 0, 200, 120))
    render(node)

    dispatch(node, InputState(50, 60, true))     // +
    rerender(node)
    layout(node, Rect(0, 0, 200, 120))
    render(node)

    dispatch(node, InputState(50, 100, true))    // toggle
    rerender(node)
    layout(node, Rect(0, 0, 200, 120))
    render(node)

    dispatch(node, InputState(50, 60, true))     // +
    rerender(node)
    layout(node, Rect(0, 0, 200, 120))
    render(node)
    0
