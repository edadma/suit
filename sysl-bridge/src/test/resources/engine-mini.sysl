// Scope 2 milestone — a sysl-side render pipeline that mirrors the
// suit toolkit's core. Sysl owns View, Node, mount, measure, layout,
// reconcile, and render; the JVM exposes only draw-emit builtins.
//
// Each Node variant wraps its mutable state in a struct: sysl analyzer
// only supports field assignment on StructType, so `node.view = v` on a
// raw enum-variant binding is rejected. Wrapping in `<Variant>State`
// gives `state.view = v` (struct-field assignment, well-trodden in
// std/) while preserving the per-variant field shapes.
//
// Variants: Text, Button, Spacer, Image, Checkbox (leaf), Sized, Center,
// Box (single-child wrappers with optional struct-typed fields), and
// Stack(gap, children: []View) (variable-arity vertical with flex
// distribution across Spacer children).

extern host_fill_rect(x: int, y: int, w: int, h: int, r: int, g: int, b: int, a: int) -> int
extern host_draw_text(x: int, y: int, text: string, r: int, g: int, b: int, a: int) -> int
extern host_draw_image(x: int, y: int, w: int, h: int, source: string) -> int

struct InputState
    mouse_x: int
    mouse_y: int
    mouse_pressed: bool

// ---- value types ----------------------------------------------------------

struct Rect
    x: int
    y: int
    w: int
    h: int

struct Size
    w: int
    h: int

struct Color
    r: int
    g: int
    b: int
    a: int

struct Insets
    top: int
    right: int
    bottom: int
    left: int

// ---- View / Node ----------------------------------------------------------

enum View
    Text(content: string)
    Button(label: string, on_click: () -> int)
    Spacer(flex: int)
    Image(source: string, width: int, height: int)
    Checkbox(label: string, checked: bool, on_toggle: (bool) -> int)
    Sized(child: View, width: int, height: int)
    Center(child: View)
    Box(child: View, color: Color, padding: Insets)
    Stack(gap: int, children: []View)

struct TextNodeState
    view: View
    bounds: Rect

struct ButtonNodeState
    view: View
    bounds: Rect
    hover: bool
    pressed: bool

struct SpacerNodeState
    view: View
    bounds: Rect

struct ImageNodeState
    view: View
    bounds: Rect

struct CheckboxNodeState
    view: View
    bounds: Rect

struct SizedNodeState
    view: View
    bounds: Rect
    child: Node

struct CenterNodeState
    view: View
    bounds: Rect
    child: Node

struct BoxNodeState
    view: View
    bounds: Rect
    child: Node

struct StackNodeState
    view: View
    bounds: Rect
    gap: int
    children: []Node

enum Node
    TextNode(s: TextNodeState)
    ButtonNode(s: ButtonNodeState)
    SpacerNode(s: SpacerNodeState)
    ImageNode(s: ImageNodeState)
    CheckboxNode(s: CheckboxNodeState)
    SizedNode(s: SizedNodeState)
    CenterNode(s: CenterNodeState)
    BoxNode(s: BoxNodeState)
    StackNode(s: StackNodeState)

// ---- Theme constants ------------------------------------------------------

const FONT_W: int    = 8
const LINE_H: int    = 18
const BTN_PAD_X: int = 12
const BTN_PAD_Y: int = 6
const CHK_GAP: int   = 6

// ---- mount: View tree → Node tree -----------------------------------------

mount(v: View) -> Node
    v match
        Text(_)           -> TextNode(TextNodeState(v, Rect(0, 0, 0, 0)))
        Button(_, _)      -> ButtonNode(ButtonNodeState(v, Rect(0, 0, 0, 0), false, false))
        Spacer(_)         -> SpacerNode(SpacerNodeState(v, Rect(0, 0, 0, 0)))
        Image(_, _, _)    -> ImageNode(ImageNodeState(v, Rect(0, 0, 0, 0)))
        Checkbox(_, _, _) -> CheckboxNode(CheckboxNodeState(v, Rect(0, 0, 0, 0)))
        Sized(c, _, _)    -> SizedNode(SizedNodeState(v, Rect(0, 0, 0, 0), mount(c)))
        Center(c)         -> CenterNode(CenterNodeState(v, Rect(0, 0, 0, 0), mount(c)))
        Box(c, _, _)      -> BoxNode(BoxNodeState(v, Rect(0, 0, 0, 0), mount(c)))
        Stack(g, kids) ->
            val n = len(kids)
            val nodes = (new [n]Node)[:]
            var i = 0
            while i < n do
                nodes[i] = mount(kids[i])
                i = i + 1
            StackNode(StackNodeState(v, Rect(0, 0, 0, 0), g, nodes))

// ---- measure: natural size ------------------------------------------------

text_w(s: string) -> int = len(s) * FONT_W

flex_of(n: Node) -> int
    n match
        SpacerNode(s) ->
            s.view match
                Spacer(f) -> f
                _         -> 0
        _ -> 0

measure(n: Node) -> Size
    n match
        TextNode(s) ->
            s.view match
                Text(c) -> Size(text_w(c), LINE_H)
                _       -> Size(0, 0)
        ButtonNode(s) ->
            s.view match
                Button(l, _) -> Size(text_w(l) + BTN_PAD_X * 2, LINE_H + BTN_PAD_Y * 2)
                _            -> Size(0, 0)
        SpacerNode(_) -> Size(0, 0)
        ImageNode(s) ->
            s.view match
                Image(_, w, h) -> Size(w, h)
                _              -> Size(0, 0)
        CheckboxNode(s) ->
            s.view match
                Checkbox(l, _, _) -> Size(LINE_H + CHK_GAP + text_w(l), LINE_H)
                _                 -> Size(0, 0)
        SizedNode(s) ->
            val cs = measure(s.child)
            s.view match
                Sized(_, w, h) ->
                    val sw = if w >= 0 then w else cs.w
                    val sh = if h >= 0 then h else cs.h
                    Size(sw, sh)
                _ -> cs
        CenterNode(s) -> measure(s.child)
        BoxNode(s) ->
            val cs = measure(s.child)
            s.view match
                Box(_, _, p) -> Size(cs.w + p.left + p.right, cs.h + p.top + p.bottom)
                _            -> cs
        StackNode(s) ->
            var w = 0
            var h = 0
            var i = 0
            while i < len(s.children) do
                val cs = measure(s.children[i])
                if cs.w > w then w = cs.w
                h = h + cs.h
                if i > 0 then h = h + s.gap
                i = i + 1
            Size(w, h)

// ---- layout: mutate bounds in place ---------------------------------------

set_rect(b: Rect, frame: Rect) -> int
    b.x = frame.x
    b.y = frame.y
    b.w = frame.w
    b.h = frame.h
    0

layout(n: Node, frame: Rect) -> int
    n match
        TextNode(s)     -> set_rect(s.bounds, frame)
        ButtonNode(s)   -> set_rect(s.bounds, frame)
        SpacerNode(s)   -> set_rect(s.bounds, frame)
        ImageNode(s)    -> set_rect(s.bounds, frame)
        CheckboxNode(s) -> set_rect(s.bounds, frame)
        SizedNode(s) ->
            set_rect(s.bounds, frame)
            layout(s.child, frame)
        CenterNode(s) ->
            val cs    = measure(s.child)
            val cx    = frame.x + (frame.w - cs.w) / 2
            val cy    = frame.y + (frame.h - cs.h) / 2
            val inner = Rect(cx, cy, cs.w, cs.h)
            // Mirror suit's CenterNode: own bounds = centered child rect so
            // hit-testing sees the rendered area, not the parent frame.
            set_rect(s.bounds, inner)
            layout(s.child, inner)
        BoxNode(s) ->
            set_rect(s.bounds, frame)
            s.view match
                Box(_, _, p) ->
                    val inner = Rect(frame.x + p.left,
                                     frame.y + p.top,
                                     frame.w - p.left - p.right,
                                     frame.h - p.top - p.bottom)
                    layout(s.child, inner)
                _ -> 0
        StackNode(s) ->
            set_rect(s.bounds, frame)
            var fixed_total = 0
            var flex_total  = 0
            var i = 0
            while i < len(s.children) do
                val f = flex_of(s.children[i])
                if f > 0 then
                    flex_total = flex_total + f
                else
                    val sz = measure(s.children[i])
                    fixed_total = fixed_total + sz.h
                i = i + 1
            val n_kids = len(s.children)
            val gaps   = if n_kids > 1 then (n_kids - 1) * s.gap else 0
            val avail0 = frame.h - fixed_total - gaps
            val flex_pool = if avail0 > 0 then avail0 else 0
            var pos = frame.y
            i = 0
            while i < len(s.children) do
                val child = s.children[i]
                val f     = flex_of(child)
                val ch    = if f > 0 && flex_total > 0 then flex_pool * f / flex_total else measure(child).h
                layout(child, Rect(frame.x, pos, frame.w, ch))
                pos = pos + ch
                if i < n_kids - 1 then pos = pos + s.gap
                i = i + 1
            0

// ---- reconcile: diff existing Node tree against a new View ---------------

// Reuse the old Node when its kind matches the new View's kind, updating
// view-bearing fields in place. Single-child wrappers (Sized/Center/Box)
// recurse on their child, possibly overwriting it with a remount. Stack
// reuses positionally only when arity matches; Stack arity-change remounts.
reconcile(old: Node, v: View) -> Node
    old match
        TextNode(state) ->
            v match
                Text(_) ->
                    state.view = v
                    old
                _ -> mount(v)
        ButtonNode(state) ->
            v match
                Button(_, _) ->
                    state.view = v
                    old
                _ -> mount(v)
        SpacerNode(state) ->
            v match
                Spacer(_) ->
                    state.view = v
                    old
                _ -> mount(v)
        ImageNode(state) ->
            v match
                Image(_, _, _) ->
                    state.view = v
                    old
                _ -> mount(v)
        CheckboxNode(state) ->
            v match
                Checkbox(_, _, _) ->
                    state.view = v
                    old
                _ -> mount(v)
        SizedNode(state) ->
            v match
                Sized(c, _, _) ->
                    state.view  = v
                    state.child = reconcile(state.child, c)
                    old
                _ -> mount(v)
        CenterNode(state) ->
            v match
                Center(c) ->
                    state.view  = v
                    state.child = reconcile(state.child, c)
                    old
                _ -> mount(v)
        BoxNode(state) ->
            v match
                Box(c, _, _) ->
                    state.view  = v
                    state.child = reconcile(state.child, c)
                    old
                _ -> mount(v)
        StackNode(state) ->
            v match
                Stack(g, kids) ->
                    if len(kids) == len(state.children) then
                        state.view = v
                        state.gap  = g
                        var i = 0
                        while i < len(kids) do
                            state.children[i] = reconcile(state.children[i], kids[i])
                            i = i + 1
                        old
                    else mount(v)
                _ -> mount(v)

// ---- render: walk and emit draw commands ----------------------------------

render(n: Node) -> int
    n match
        TextNode(s) ->
            s.view match
                Text(c) ->
                    host_draw_text(s.bounds.x, s.bounds.y + 14, c, 220, 220, 240, 255)
                    0
                _ -> 0
        ButtonNode(s) ->
            s.view match
                Button(l, _) ->
                    host_fill_rect(s.bounds.x, s.bounds.y, s.bounds.w, s.bounds.h,
                                   40, 40, 55, 255)
                    host_draw_text(s.bounds.x + BTN_PAD_X, s.bounds.y + BTN_PAD_Y + 14, l,
                                   220, 220, 240, 255)
                    0
                _ -> 0
        SpacerNode(_) -> 0
        ImageNode(s) ->
            s.view match
                Image(src, _, _) ->
                    host_draw_image(s.bounds.x, s.bounds.y, s.bounds.w, s.bounds.h, src)
                    0
                _ -> 0
        CheckboxNode(s) ->
            s.view match
                Checkbox(l, checked, _) ->
                    host_fill_rect(s.bounds.x, s.bounds.y, LINE_H, LINE_H, 60, 60, 80, 255)
                    if checked then
                        host_fill_rect(s.bounds.x + 4, s.bounds.y + 4, LINE_H - 8, LINE_H - 8, 220, 220, 240, 255)
                    host_draw_text(s.bounds.x + LINE_H + CHK_GAP, s.bounds.y + 14, l, 220, 220, 240, 255)
                    0
                _ -> 0
        SizedNode(s)  -> render(s.child)
        CenterNode(s) -> render(s.child)
        BoxNode(s) ->
            s.view match
                Box(_, c, _) ->
                    host_fill_rect(s.bounds.x, s.bounds.y, s.bounds.w, s.bounds.h,
                                   c.r, c.g, c.b, c.a)
                    render(s.child)
                    0
                _ -> render(s.child)
        StackNode(s) ->
            var i = 0
            while i < len(s.children) do
                render(s.children[i])
                i = i + 1
            0

// ---- dispatch: hit-test interactives, fire closures -----------------------

contains(b: Rect, x: int, y: int) -> bool
    x >= b.x && x < b.x + b.w && y >= b.y && y < b.y + b.h

dispatch(n: Node, input: InputState) -> int
    n match
        ButtonNode(s) ->
            if input.mouse_pressed && contains(s.bounds, input.mouse_x, input.mouse_y) then
                s.view match
                    Button(_, on_click) ->
                        on_click()
                        0
                    _ -> 0
            else 0
        CheckboxNode(s) ->
            if input.mouse_pressed && contains(s.bounds, input.mouse_x, input.mouse_y) then
                s.view match
                    Checkbox(_, checked, on_toggle) ->
                        on_toggle(!checked)
                        0
                    _ -> 0
            else 0
        SizedNode(s)  -> dispatch(s.child, input)
        CenterNode(s) -> dispatch(s.child, input)
        BoxNode(s)    -> dispatch(s.child, input)
        StackNode(s) ->
            var i = 0
            while i < len(s.children) do
                dispatch(s.children[i], input)
                i = i + 1
            0
        _ -> 0

// ---- driver entry ---------------------------------------------------------

main() -> int
    noop = () -> 0
    val kids1 = (new [2]View)[:]
    kids1[0] = Text("Hello, sysl!")
    kids1[1] = Button("Click me", noop)
    val v1 = Stack(6, kids1)
    val n  = mount(v1)
    layout(n, Rect(0, 0, 200, 100))
    render(n)

    val kids2 = (new [2]View)[:]
    kids2[0] = Text("Hello, AGAIN!")
    kids2[1] = Button("Click me too", noop)
    val v2 = Stack(6, kids2)
    reconcile(n, v2)
    layout(n, Rect(0, 0, 200, 100))
    render(n)
    0
